# ─── APPLICATION ───────────────────────────────────────────────
APP_NAME=TelegramAgent
APP_ENV=production
DEBUG=false
SECRET_KEY=your-super-secret-key-change-this-in-production
API_KEY=your-api-key-for-rest-access

# ─── DATABASE ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/telegram_agent
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ─── REDIS ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_QUEUE_URL=redis://redis:6379/1
REDIS_CACHE_TTL=3600

# ─── TELEGRAM API ──────────────────────────────────────────────
# نیازی به تغییر این مقادیر نیست — پیش‌فرض‌ها به صورت خودکار استفاده می‌شوند
# TELEGRAM_API_ID=2040
# TELEGRAM_API_HASH=b18441a1ff607e10a989891a5462e627

# ─── ADMIN BOT (BotFather bot token) ──────────────────────────
ADMIN_BOT_TOKEN=your_admin_bot_token
ADMIN_TELEGRAM_IDS=123456789,987654321

# ─── AI PROVIDER ───────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.7

# ─── ANTI-SPAM ─────────────────────────────────────────────────
SPAM_MAX_MESSAGES_PER_MINUTE=5
SPAM_MAX_MESSAGES_PER_HOUR=30
SPAM_SCORE_THRESHOLD=0.8

# ─── MONITORING & ALERTS ───────────────────────────────────────
ALERT_CPU_THRESHOLD=85
ALERT_RAM_THRESHOLD=90
ALERT_DISK_THRESHOLD=90
HEALTH_CHECK_INTERVAL=60

# ─── CONTENT & PUBLISHING ─────────────────────────────────────
POST_DEFAULT_TIMEZONE=Asia/Tehran
MAX_CHANNELS_PER_POST=20
CONTENT_DEFAULT_LANGUAGES=en,fa
CONTENT_HASHTAGS_ENABLED=true

# ─── SECURITY ─────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
ALLOWED_HOSTS=*
CORS_ORIGINS=http://localhost:3000

# ─── AI BEHAVIOR ──────────────────────────────────────────────
REPLY_TYPING_MIN_DELAY=0.5
REPLY_TYPING_MAX_DELAY=4.0
ENABLE_HUMANLIKE_DELAYS=true
AI_FACT_EXTRACTION_INTERVAL=10

# ─── SALES & LEADS ────────────────────────────────────────────
HOT_LEAD_SCORE_THRESHOLD=0.7
HOT_LEAD_ALERTS_ENABLED=true

# ─── FOLLOW-UP SEQUENCES ──────────────────────────────────────
FOLLOWUP_ENABLED=true
FOLLOWUP_STAGE1_HOURS=24
FOLLOWUP_STAGE2_HOURS=72
FOLLOWUP_STAGE3_HOURS=168

# ─── LEARNING & QUALITY ───────────────────────────────────────
LEARNING_AUTO_APPROVE_THRESHOLD=0.85
LEARNING_MIN_MESSAGES_FOR_SAMPLE=4

# ─── CRYPTO WALLET ADDRESSES ─────────────────────────────────────────
# Set these as secret environment variables in Render dashboard.
# Any wallet left empty will be hidden from customers automatically.
WALLET_BTC=bc1qxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WALLET_ETH=0xYourEthereumAddressHere
WALLET_USDT_TRC20=TYourTronUSDTAddressHere
WALLET_USDT_ERC20=0xYourERC20USDTAddressHere
WALLET_LTC=LYourLitecoinAddressHere
WALLET_BNB=0xYourBNBAddressHere
WALLET_TRX=TYourTRONAddressHere
